{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "System Monitor",
  "version": "0.2.0",
  "identifier": "dev.xsaitox.system-monitor",
  "build": {
    "beforeDevCommand": "bun run vite:dev -- --port 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "System Monitor",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "center": true
      },
      {
        "label": "overlay",
        "title": "System Monitor Overlay",
        "width": 320,
        "height": 200,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src https://speed.cloudflare.com https://github.com https://objects.githubusercontent.com https://api.github.com; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIwNUYyMzVEOTNGRDBEMTMKUldRVERmMlRYU05mc0xZS1hxeEFLNEg5M0JrSVRUVy81RWtVUzdFYkNEQVNIaFdpZktOR29UZEkK",
      "endpoints": [
        "https://github.com/XSaitoKungX/System-Monitor/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": { "depends": [] },
      "appimage": { "bundleMediaFramework": true }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["English"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
