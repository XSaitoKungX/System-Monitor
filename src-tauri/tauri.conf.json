{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "System Monitor",
  "version": "0.1.0",
  "identifier": "dev.xsaitox.system-monitor",
  "build": {
    "beforeDevCommand": "bun run vite:dev -- --port 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "System Monitor",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "center": true
      },
      {
        "label": "overlay",
        "title": "System Monitor Overlay",
        "width": 320,
        "height": 200,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": { "depends": [] },
      "appimage": { "bundleMediaFramework": true }
    }
  }
}
