# ── Node / Bun ───────────────────────────────────────────────────────────────
node_modules/
package-lock.json

# ── Vite build output ────────────────────────────────────────────────────────
dist/
dist-ssr/
*.local

# ── Tauri ────────────────────────────────────────────────────────────────────
# Rust build artefacts (also covered by src-tauri/.gitignore)
src-tauri/target/
# Tauri-generated schema files for capability autocomplete
src-tauri/gen/schemas/

# ── Rust ─────────────────────────────────────────────────────────────────────
# Cargo.lock is intentionally tracked for binary crates — do NOT ignore it

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Misc ─────────────────────────────────────────────────────────────────────
.cache/
.temp/
*.bak
*.orig
